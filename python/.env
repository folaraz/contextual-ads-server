# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=contextual_ads
POSTGRES_USER=adsuser
POSTGRES_PASSWORD=adspassword
PG_MIN_CONN=2
PG_MAX_CONN=10

# =============================================================================
# Kafka - Common Settings
# =============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_AUTO_COMMIT=false
KAFKA_MAX_RETRIES=3
KAFKA_MAX_POLL_INTERVAL_MS=600000
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_HEARTBEAT_INTERVAL_MS=15000
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# =============================================================================
# Kafka - Ad Consumer (run_job.py ad)
# Topic: ad_analyze | Group: ad_processor_group
# =============================================================================
AD_CONSUMER_TOPIC=ad_analyze
AD_CONSUMER_GROUP=ad_processor_group

# =============================================================================
# Kafka - Page Consumer (run_job.py page)
# Topic: page_analyze | Group: page_processor_group
# =============================================================================
PAGE_CONSUMER_TOPIC=page_analyze
PAGE_CONSUMER_GROUP=page_processor_group

# =============================================================================
# Kafka - Event Consumer (run_job.py event)
# Topic: ad_event | Group: event_aggregator_group
# =============================================================================
EVENT_CONSUMER_TOPICS=ad_event
EVENT_CONSUMER_GROUP=event_aggregator_group

# =============================================================================
# Flink
# =============================================================================
FLINK_PARALLELISM=1
FLINK_CHECKPOINT_INTERVAL_MS=60000
FLINK_CHECKPOINT_DIR=file:///tmp/flink-checkpoints
FLINK_WINDOW_SIZE_SECONDS=10

# =============================================================================
# Sinks
# =============================================================================
SINK_POSTGRES_ENABLED=true
SINK_REDIS_ENABLED=false
SINK_CLICKHOUSE_ENABLED=false

# =============================================================================
# ClickHouse (if enabled)
# =============================================================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=ads_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =============================================================================
# Pacing Worker (run_job.py pacing)
# Publishes to Kafka topic: pacing_events
# =============================================================================
PACING_INTERVAL_SECONDS=60

# =============================================================================
# Kafka - Pacing Consumer (run_job.py pacing_history)
# Topic: pacing_events | Group: pacing_history_group
# Consumes pacing events and writes to ClickHouse
# =============================================================================
PACING_CONSUMER_TOPICS=pacing_events
PACING_CONSUMER_GROUP=pacing_history_group

# =============================================================================
# Crawler - Ad Consumer Settings
# =============================================================================
AD_ENABLE_CRAWLER=false
AD_CRAWL_LANDING_PAGES=false
AD_CRAWLER_USER_AGENT="Mozilla/5.0 (compatible; contextual-ads-bot/1.0)"
AD_CRAWLER_HEADLESS=true
AD_CRAWLER_TIMEOUT=30
AD_CRAWLER_MAX_RETRIES=3
AD_CRAWLER_CACHE_ENABLED=true

# =============================================================================
# Crawler - Page Consumer Settings
# =============================================================================
PAGE_ENABLE_CRAWLER=true
PAGE_AUTO_CRAWL=true
PAGE_CRAWLER_USER_AGENT="Mozilla/5.0 (compatible; contextual-ads-bot/1.0)"
PAGE_CRAWLER_HEADLESS=true
PAGE_CRAWLER_TIMEOUT=30
PAGE_CRAWLER_MAX_RETRIES=3
PAGE_CRAWLER_CACHE_ENABLED=true

# =============================================================================
# Processing
# =============================================================================
BATCH_SIZE=5
MAX_RETRIES=3
RETRY_DELAY_MS=1000
